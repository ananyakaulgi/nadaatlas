# ── App ──────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Database ─────────────────────────────────────────────────────
POSTGRES_USER=nadaatlas
POSTGRES_PASSWORD=change-me
POSTGRES_DB=nadaatlas
DATABASE_URL=postgresql+asyncpg://nadaatlas:change-me@postgres:5432/nadaatlas

# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0

# ── Elasticsearch ────────────────────────────────────────────────
ELASTIC_PASSWORD=change-me
ELASTICSEARCH_URL=http://elasticsearch:9200

# ── MinIO / Object Storage ───────────────────────────────────────
MINIO_ROOT_USER=nadaatlas
MINIO_ROOT_PASSWORD=change-me
MINIO_ACCESS_KEY=nadaatlas
MINIO_SECRET_KEY=change-me
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=nadaatlas

# ── JWT ──────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=secrets/jwt_public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── External APIs ─────────────────────────────────────────────────
MUSICBRAINZ_APP_NAME=NadaAtlas
MUSICBRAINZ_VERSION=0.1.0
MUSICBRAINZ_CONTACT=your@email.com
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YOUTUBE_API_KEY=

# ── Monitoring ───────────────────────────────────────────────────
SENTRY_DSN=

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── API Reload (dev only) ─────────────────────────────────────────
# Set to --reload to enable Uvicorn auto-reload in development
API_RELOAD=--reload
